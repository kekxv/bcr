{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bcr.bazel.build/metadata.schema.json",
  "title": "Bazel Central Registry Module Metadata",
  "description": "Schema for module metadata.json files",
  "type": "object",
  "required": ["homepage", "maintainers", "repository", "versions"],
  "properties": {
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "URL to the module's homepage"
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["email", "github"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "Maintainer's email address"
          },
          "github": {
            "type": "string",
            "description": "GitHub username"
          },
          "github_user_id": {
            "type": "integer",
            "description": "GitHub user ID (numeric)"
          },
          "name": {
            "type": "string",
            "description": "Full name of the maintainer"
          }
        }
      }
    },
    "repository": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^(github|gitlab|bitbucket):[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+$",
        "description": "Repository identifier in the format 'host:owner/name'"
      }
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[a-zA-Z0-9_.-]+)?$",
        "description": "Semantic version strings"
      }
    },
    "yanked_versions": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "description": "Reason for yanking the version"
      },
      "description": "Map of yanked version to reason"
    },
    "deprecated": {
      "type": "string",
      "description": "Deprecation message explaining why the module is deprecated"
    }
  },
  "additionalProperties": false
}
