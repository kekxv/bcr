# SDL3 main library with platform-specific entry point
cc_library(
    name = "sdl3",
    srcs = select({
        ":windows": ["src/main/windows/SDL_sysmain_runapp.c"],
        "//conditions:default": [],
    }),
    deps = [
        ":SDL3Library",
        ":sdl3_private_headers",
    ],
)

# Alias for convenience
alias(
    name = "SDL3",
    actual = ":sdl3",
)

