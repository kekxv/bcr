# Configuration flags
bool_flag(
    name = "shared_memory",
    build_setting_default = False,
)

bool_flag(
    name = "opengl",
    build_setting_default = False,
)

bool_flag(
    name = "vulkan",
    build_setting_default = True,
)

bool_flag(
    name = "x11",
    build_setting_default = True,
)

bool_flag(
    name = "wayland",
    build_setting_default = False,
)

bool_flag(
    name = "alsa",
    build_setting_default = False,
)

bool_flag(
    name = "pulseaudio",
    build_setting_default = False,
)

bool_flag(
    name = "opengles",
    build_setting_default = False,
)

bool_flag(
    name = "camera",
    build_setting_default = False,
)

# Platform config settings
config_setting(
    name = "shared_memory_disabled",
    flag_values = {":shared_memory": "False"},
)

config_setting(
    name = "opengl_enabled",
    flag_values = {":opengl": "True"},
)

config_setting(
    name = "linux",
    constraint_values = ["@platforms//os:linux"],
)

config_setting(
    name = "linux_opengl",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {":opengl": "True"},
)

config_setting(
    name = "linux_x11",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {":x11": "True"},
)

config_setting(
    name = "linux_alsa",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {":alsa": "True"},
)

config_setting(
    name = "linux_pulseaudio",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {":pulseaudio": "True"},
)

config_setting(
    name = "linux_camera",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {":camera": "True"},
)

config_setting(
    name = "linux_opengles",
    constraint_values = ["@platforms//os:linux"],
    flag_values = {":opengles": "True"},
)

config_setting(
    name = "linux_arm",
    constraint_values = [
        "@platforms//os:linux",
        "@platforms//cpu:arm",
    ],
)

config_setting(
    name = "macos",
    constraint_values = ["@platforms//os:macos"],
)

config_setting(
    name = "windows",
    constraint_values = ["@platforms//os:windows"],
)

# Autoconf targets for dynamic feature detection (native builds only)
# For cross-compilation, use the predefined config headers
autoconf(
    name = "sdl3_linux_config",
    checks = SDL3_CONFIG_CHECKS_LINUX,
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:private"],
)

autoconf(
    name = "sdl3_macos_config",
    checks = SDL3_CONFIG_CHECKS_MACOS,
    target_compatible_with = ["@platforms//os:macos"],
    visibility = ["//visibility:private"],
)

autoconf(
    name = "sdl3_windows_config",
    checks = SDL3_CONFIG_CHECKS_WINDOWS,
    target_compatible_with = ["@platforms//os:windows"],
    visibility = ["//visibility:private"],
)

# Header libraries
cc_library(
    name = "sdl3_build_config",
    hdrs = glob(["include/build_config/*.h"], exclude = [
        "include/build_config/SDL_build_config.h.in",
    ]),
    includes = ["include/build_config"],
    strip_include_prefix = "include",
    visibility = ["//visibility:private"],
)

cc_library(
    name = "sdl3_headers",
    hdrs = glob(["include/SDL3/*.h"]),
    deps = [
        ":sdl3_build_config",
    ],
    strip_include_prefix = "include",
    visibility = ["//visibility:public"],
)

cc_library(
    name = "sdl3_khronos_headers",
    hdrs = glob(["src/video/khronos/**/*.h"]),
    strip_include_prefix = "src/video/khronos",
    visibility = ["//visibility:private"],
)

cc_library(
    name = "sdl3_private_headers",
    hdrs = glob(["src/**/*.h"]),
    includes = ["src"],
    deps = [
        ":sdl3_build_config",
        ":sdl3_headers",
        ":sdl3_khronos_headers",
    ],
    visibility = ["//visibility:private"],
)

