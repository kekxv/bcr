    name = "clay",
    hdrs = ["clay.h"],
    copts = [
        "-std=c99",
    ] + select({
        "@platforms//os:windows": [],
        "//conditions:default": [
            "-Wall",
            "-Wextra",
            "-Wno-unused-function",
        ],
    }),
