<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{REPO_NAME}} - Bazel Registry</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #1976d2;
            --primary-dark: #1565c0;
            --primary-light: #42a5f5;
            --primary-bg: #e3f2fd;
            --bg: #f8fafc;
            --surface: #ffffff;
            --surface-hover: #f1f5f9;
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --text-muted: #94a3b8;
            --border: #e2e8f0;
            --border-light: #f1f5f9;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.08), 0 2px 4px -1px rgba(0,0,0,0.04);
            --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04);
            --radius: 12px;
            --radius-sm: 8px;
            --code-bg: #f8fafc;
            --code-border: #e2e8f0;
            --success: #22c55e;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            line-height: 1.6;
            background: var(--bg);
            color: var(--text-primary);
            min-height: 100vh;
        }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

        /* Header */
        header {
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            padding: 20px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            flex-wrap: wrap;
        }
        .brand { display: flex; align-items: center; gap: 12px; }
        .logo {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: white;
            font-size: 18px;
            box-shadow: var(--shadow-sm);
        }
        .brand-text h1 { font-size: 1.4rem; font-weight: 700; color: var(--text-primary); line-height: 1.2; }
        .brand-text p { font-size: 0.85rem; color: var(--text-secondary); }

        /* Search */
        .search-box {
            position: relative;
            flex: 1;
            max-width: 400px;
            min-width: 200px;
        }
        .search-box input {
            width: 100%;
            padding: 10px 16px 10px 40px;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.95rem;
            background: var(--surface);
            color: var(--text-primary);
            transition: all 0.2s;
        }
        .search-box input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(25, 118, 210, 0.1);
        }
        .search-box input::placeholder { color: var(--text-muted); }
        .search-box svg {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            width: 18px;
            height: 18px;
        }
        .search-stats {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-top: 8px;
            min-height: 20px;
        }

        /* Hero */
        .hero { padding: 40px 0 32px; }
        .hero-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            text-align: center;
            transition: all 0.2s ease;
            box-shadow: var(--shadow-sm);
        }
        .stat-card:hover {
            border-color: var(--primary-light);
            box-shadow: var(--shadow);
            transform: translateY(-2px);
        }
        .stat-value { font-size: 1.8rem; font-weight: 700; color: var(--primary); line-height: 1; }
        .stat-label { font-size: 0.875rem; color: var(--text-secondary); margin-top: 6px; font-weight: 500; }

        /* Usage Card */
        .usage-card {
            background: var(--code-bg);
            border: 1px solid var(--code-border);
            border-radius: var(--radius);
            padding: 20px;
            margin-bottom: 32px;
        }
        .usage-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }
        .usage-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
            font-size: 0.85rem;
            font-weight: 500;
        }
        .usage-code {
            font-family: 'JetBrains Mono', 'SF Mono', monospace;
            font-size: 0.9rem;
            color: var(--text-primary);
            line-height: 1.7;
            background: white;
            padding: 16px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            position: relative;
        }
        .usage-code .comment { color: var(--text-muted); }
        .usage-code .keyword { color: #7c3aed; font-weight: 500; }
        .usage-code .string { color: #059669; }
        .usage-code .flag { color: var(--primary); font-weight: 500; }

        /* Copy Button */
        .copy-btn {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.75rem;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.15s;
            font-family: inherit;
        }
        .copy-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }
        .copy-btn.copied {
            border-color: var(--success);
            color: var(--success);
        }
        .copy-btn svg {
            width: 12px;
            height: 12px;
        }

        /* Section Title */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 20px;
        }
        .section-title {
            font-size: 1.2rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-primary);
        }

        /* Modules Grid */
        .modules-grid { display: grid; gap: 12px; }
        .module-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            transition: all 0.2s ease;
            box-shadow: var(--shadow-sm);
        }
        .module-card:hover {
            border-color: var(--primary-light);
            box-shadow: var(--shadow);
            transform: translateY(-1px);
        }
        .module-card.hidden { display: none; }

        /* Module Header */
        .module-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 8px;
        }
        .module-title {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .module-icon {
            width: 36px;
            height: 36px;
            background: var(--primary-bg);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
        }
        .module-icon svg { width: 20px; height: 20px; }
        .module-name {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-primary);
        }
        .module-name a {
            color: inherit;
            text-decoration: none;
        }
        .module-name a:hover {
            color: var(--primary);
        }
        .module-actions {
            display: flex;
            gap: 8px;
        }
        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 10px;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 0.75rem;
            color: var(--text-secondary);
            text-decoration: none;
            transition: all 0.15s;
        }
        .action-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-bg);
        }
        .action-btn svg { width: 14px; height: 14px; }

        .module-homepage {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin: 0 0 8px 46px;
        }
        .module-homepage a {
            color: var(--primary);
            text-decoration: none;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 400px;
        }
        .module-homepage a:hover { text-decoration: underline; }

        /* Versions */
        .versions-section { margin: 8px 0 0 46px; }
        .versions { display: flex; flex-wrap: wrap; gap: 4px; }
        .version {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: var(--primary-bg);
            border: 1px solid transparent;
            border-radius: var(--radius-sm);
            padding: 2px 8px;
            font-size: 0.75rem;
            font-family: 'JetBrains Mono', monospace;
            color: var(--primary-dark);
            font-weight: 500;
            transition: all 0.15s ease;
            cursor: pointer;
        }
        .version:hover {
            background: var(--primary);
            color: white;
        }
        .version.copied { background: var(--success); color: white; }
        .version.yanked {
            background: #fef2f2;
            color: #dc2626;
        }
        .version-more {
            background: var(--bg);
            border: 1px dashed var(--border);
            color: var(--text-muted);
            cursor: pointer;
        }
        .version-more:hover {
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-bg);
        }
        .versions-collapsed { display: none; }
        .versions-collapsed.show { display: flex; }

        /* Quick dep code */
        .quick-dep {
            margin: 8px 0 0 46px;
            padding: 8px 12px;
            background: var(--code-bg);
            border: 1px solid var(--code-border);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
        }
        .quick-dep-code {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--text-primary);
        }
        .deprecated-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #fff7ed;
            border: 1px solid #fed7aa;
            color: #ea580c;
            padding: 3px 10px;
            border-radius: var(--radius-sm);
            font-size: 0.75rem;
            font-weight: 500;
            margin-top: 10px;
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 80px 24px;
            color: var(--text-secondary);
            background: var(--surface);
            border: 2px dashed var(--border);
            border-radius: var(--radius);
        }
        .empty-state-icon {
            width: 64px;
            height: 64px;
            margin: 0 auto 16px;
            background: var(--bg);
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
        }
        .empty-state h3 { font-size: 1.1rem; margin-bottom: 8px; color: var(--text-primary); }
        .no-results {
            display: none;
            text-align: center;
            padding: 60px 24px;
            color: var(--text-secondary);
        }
        .no-results.show { display: block; }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 24px;
            right: 24px;
            padding: 12px 20px;
            background: var(--text-primary);
            color: white;
            border-radius: var(--radius-sm);
            font-size: 0.9rem;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.3s ease;
            z-index: 1000;
        }
        .toast.show {
            opacity: 1;
            transform: translateY(0);
        }

        /* Footer */
        footer {
            border-top: 1px solid var(--border);
            padding: 24px 0;
            margin-top: 48px;
            text-align: center;
            font-size: 0.875rem;
            color: var(--text-secondary);
        }
        footer a { color: var(--primary); text-decoration: none; }
        footer a:hover { text-decoration: underline; }

        /* Responsive */
        @media (max-width: 640px) {
            .header-content { flex-direction: column; align-items: stretch; }
            .search-box { max-width: none; order: 1; margin-top: 12px; }
            .hero-stats { grid-template-columns: repeat(2, 1fr); }
            .module-homepage a { max-width: 250px; }
            .section-header { flex-direction: column; align-items: flex-start; }
            .module-header { flex-direction: column; }
            .quick-dep { flex-direction: column; align-items: stretch; }
            .versions-header { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <header>
        <div class="container">
            <div class="header-content">
                <div class="brand">
                    <div class="logo">B</div>
                    <div class="brand-text">
                        <h1>{{REPO_NAME}}</h1>
                        <p>Bazel Central Registry</p>
                    </div>
                </div>
                <div class="search-box">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <input type="text" id="searchInput" placeholder="Search modules..." autocomplete="off">
                </div>
            </div>
            <div class="search-stats" id="searchStats"></div>
        </div>
    </header>

    <main class="container">
        <section class="hero">
            <div class="hero-stats">
                <div class="stat-card">
                    <div class="stat-value" id="statModules">{{MODULE_COUNT}}</div>
                    <div class="stat-label">Modules</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="statVersions">{{VERSION_COUNT}}</div>
                    <div class="stat-label">Versions</div>
                </div>
            </div>

            <div class="usage-card">
                <div class="usage-header">
                    <div class="usage-title">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                        Quick Start
                    </div>
                    <button class="copy-btn" data-copy="common --registry={{REGISTRY_URL}}
common --registry=https://bcr.bazel.build  # default bcr">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                        Copy
                    </button>
                </div>
                <div class="usage-code">
                    <span class="comment"># In your MODULE.bazel</span><br>
                    <span class="keyword">bazel_dep</span>(<span class="string">name</span> = <span class="string">"module_name"</span>, <span class="string">version</span> = <span class="string">"1.0.0"</span>)<br><br>
                    <span class="comment"># Add to your .bazelrc</span><br>
                    <span class="flag">common</span> <span class="comment">--registry={{REGISTRY_URL}}</span><br>
                    <span class="flag">common</span> <span class="comment">--registry=https://bcr.bazel.build  # default bcr</span>
                </div>
            </div>
        </section>

        <section class="modules">
            <div class="section-header">
                <h2 class="section-title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
                    Available Modules
                </h2>
            </div>

            <div class="no-results" id="noResults">
                <div class="empty-state-icon">🔍</div>
                <h3>No modules found</h3>
                <p>Try adjusting your search terms</p>
            </div>

            {{MODULES_HTML}}
        </section>
    </main>

    <footer>
        <div class="container">
            <p>Generated by <a href="https://github.com/{{REPO_NAME}}" target="_blank">{{REPO_NAME}}</a></p>
        </div>
    </footer>

    <div class="toast" id="toast">Copied to clipboard!</div>

    <script>
        (function() {
            const searchInput = document.getElementById('searchInput');
            const searchStats = document.getElementById('searchStats');
            const noResults = document.getElementById('noResults');
            const toast = document.getElementById('toast');
            const moduleCards = document.querySelectorAll('.module-card');

            // Toast notification
            function showToast(message) {
                toast.textContent = message;
                toast.classList.add('show');
                setTimeout(() => toast.classList.remove('show'), 2000);
            }

            // Copy to clipboard
            async function copyToClipboard(text, btn) {
                try {
                    await navigator.clipboard.writeText(text);
                    const originalText = btn.innerHTML;
                    btn.classList.add('copied');
                    btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied`;
                    showToast('Copied to clipboard!');
                    setTimeout(() => {
                        btn.classList.remove('copied');
                        btn.innerHTML = originalText;
                    }, 2000);
                } catch (err) {
                    showToast('Failed to copy');
                }
            }

            // Copy buttons
            document.querySelectorAll('[data-copy]').forEach(btn => {
                btn.addEventListener('click', () => copyToClipboard(btn.dataset.copy, btn));
            });

            // Version copy
            document.querySelectorAll('.version[data-dep]').forEach(version => {
                version.addEventListener('click', async () => {
                    const dep = version.dataset.dep;
                    try {
                        await navigator.clipboard.writeText(dep);
                        version.classList.add('copied');
                        showToast('Copied: ' + dep);
                        setTimeout(() => version.classList.remove('copied'), 1500);
                    } catch (err) {
                        showToast('Failed to copy');
                    }
                });
            });

            // Expand versions
            document.querySelectorAll('.version-more').forEach(btn => {
                btn.addEventListener('click', function() {
                    const card = this.closest('.module-card');
                    const collapsed = card.querySelector('.versions-collapsed');
                    collapsed.classList.add('show');
                    this.style.display = 'none';
                });
            });

            // Search
            function updateStats(visibleCount, totalCount) {
                if (searchInput.value) {
                    searchStats.textContent = `Showing ${visibleCount} of ${totalCount} modules`;
                } else {
                    searchStats.textContent = '';
                }
            }

            function filterModules() {
                const query = searchInput.value.toLowerCase().trim();
                let visibleCount = 0;
                const totalCount = moduleCards.length;

                moduleCards.forEach(card => {
                    const name = card.dataset.name || '';
                    const versions = card.dataset.versions || '';
                    const homepage = card.dataset.homepage || '';

                    const matches = !query ||
                        name.includes(query) ||
                        versions.includes(query) ||
                        homepage.includes(query);

                    if (matches) {
                        card.classList.remove('hidden');
                        visibleCount++;
                    } else {
                        card.classList.add('hidden');
                    }
                });

                updateStats(visibleCount, totalCount);
                noResults.classList.toggle('show', visibleCount === 0 && query);
            }

            searchInput.addEventListener('input', filterModules);

            // Initialize
            moduleCards.forEach(card => {
                const nameEl = card.querySelector('.module-name');
                const versionsEl = card.querySelector('.versions');
                const homepageEl = card.querySelector('.module-homepage a');

                if (nameEl) card.dataset.name = nameEl.textContent.trim().toLowerCase();
                if (versionsEl) card.dataset.versions = versionsEl.textContent.trim().toLowerCase();
                if (homepageEl) card.dataset.homepage = homepageEl.textContent.trim().toLowerCase();
            });
        })();
    </script>
</body>
</html>
